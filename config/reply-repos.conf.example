# Reply drafter (Ctrl+Cmd+S) + PR reviewer (Ctrl+Cmd+P) config.
# Copy to ~/.config/voice-setup/reply-repos.conf and edit with YOUR values.

# Base directory that holds your repos
GIT_BASE="$HOME/Documents/git"

# Main repo — opened as the working dir for the reply drafter
PRIMARY_REPO="my-main-repo"

# Other repos to also search, space-separated dir names under GIT_BASE
EXTRA_REPOS="my-second-repo my-third-repo"

# First-person voice for replies
USER_NAME="me"

# gh account that PR reviews (Ctrl+Cmd+P) post under (must be logged in via
# `gh auth login`). Leave empty to use whichever account gh has active.
GH_ACCOUNT=""
